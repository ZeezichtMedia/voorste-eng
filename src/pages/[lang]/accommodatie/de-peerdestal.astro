---
import Layout from '../../../layouts/Layout.astro';
import ScrollReveal from '../../../components/ui/ScrollReveal.astro';
import CategorizedGallery from '../../../components/ui/CategorizedGallery.astro';
import RoomHero from '../../../components/ui/RoomHero.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'nl' } },
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;

const categoryImages = [
  [
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/209b336b-6006-4b58-a8dc-afdcce36808e.avif", alt: "Wonen & Ontspannen foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/fdd358b2-3836-4a5d-9373-f40fe885449f.avif", alt: "Wonen & Ontspannen foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/822e2868-e56e-4923-b62c-5f87860989ee.avif", alt: "Wonen & Ontspannen foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/9ac8d810-cb7e-4339-a251-fff4e1a966aa.avif", alt: "Wonen & Ontspannen foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/4a5e16e5-01c3-4afc-871e-4c063d9d6043.avif", alt: "Wonen & Ontspannen foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/a36a21cf-4e0b-4bf6-800a-03cb4d80f21d.avif", alt: "Wonen & Ontspannen foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/97b293d6-77bf-4b04-97d1-a7e7f0e41a3d.avif", alt: "Wonen & Ontspannen foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Woonkamer/1998aad2-e11a-4cc3-8f2e-da652f98e5a2.avif", alt: "Wonen & Ontspannen foto" },
  ],
  [
    { src: "/images/real/rooms/peerdestal/fotos-2026/keuken/5a6fc0eb-0c38-475c-a2b2-a9a294d33810.avif", alt: "Koken & Genieten foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/keuken/27d2dd18-485a-4c66-948e-71477da61d29.avif", alt: "Koken & Genieten foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/keuken/eacd4ae2-549d-42bf-b1c4-2b7de51c3669.avif", alt: "Koken & Genieten foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/keuken/668881e0-e4e4-464e-b579-66e229d3f0e3.avif", alt: "Koken & Genieten foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/keuken/c5bdd7f9-074f-449a-bde5-42bb71859ced.avif", alt: "Koken & Genieten foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/keuken/c5cee87f-f453-41cf-b445-a33e237ffd2c.avif", alt: "Koken & Genieten foto" },
  ],
  [
    { src: "/images/real/rooms/peerdestal/fotos-2026/Slaapkamer/ab244a02-9954-4a22-b2c3-5f111399cf17.avif", alt: "Rust & Slaap foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Slaapkamer/4a924d73-b2e3-41a9-bf30-3e1c06f72a3f.avif", alt: "Rust & Slaap foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Slaapkamer/60593157-a68e-4091-bc4b-5bb6f1b90255.avif", alt: "Rust & Slaap foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Slaapkamer/e4611e7e-1f59-45c1-bd24-a834c71b8aca.avif", alt: "Rust & Slaap foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Slaapkamer/24c451c8-f53c-40ad-9953-1d6da994c5fc.avif", alt: "Rust & Slaap foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Slaapkamer/f88455e7-006e-4117-a38d-61fbef96949e.avif", alt: "Rust & Slaap foto" },
  ],
  [
    { src: "/images/real/rooms/peerdestal/fotos-2026/Badkamer/04afb8c0-0a8d-43cd-9d16-915f103c6338.avif", alt: "Fris & Verzorgd foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Badkamer/1ae99fa8-e032-45e6-9106-577e8a314a07.avif", alt: "Fris & Verzorgd foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/Badkamer/e1add379-44d7-4c17-b91e-a42c7fdbc478.avif", alt: "Fris & Verzorgd foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/toiletruimte/cc139402-6693-4431-94be-2dc848b38a0f.avif", alt: "Fris & Verzorgd foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/toiletruimte/67be2e9a-9655-40ab-b447-e00e33bb4653.avif", alt: "Fris & Verzorgd foto" },
  ],
  [
    { src: "/images/real/rooms/peerdestal/fotos-2026/terras/7fbab5cc-613a-4c8f-9ae4-8944390e72b7.avif", alt: "Buitenleven foto" },
    { src: "/images/real/rooms/peerdestal/fotos-2026/terras/652d1baa-768d-4e60-b9aa-0c3462328e01.avif", alt: "Buitenleven foto" },
  ],
];

const categoryTitles = {
  nl: ["Woonkamer", "Keuken", "Slaapkamer", "Badkamer", "Terras & Tuin"],
  en: ["Living Room", "Kitchen", "Bedroom", "Bathroom", "Terrace & Garden"],
  de: ["Wohnzimmer", "Küche", "Schlafzimmer", "Badezimmer", "Terrasse & Garten"]
};

const galleryCategories = {
  nl: categoryTitles.nl.map((title, i) => ({ title, images: categoryImages[i] })),
  en: categoryTitles.en.map((title, i) => ({ title, images: categoryImages[i] })),
  de: categoryTitles.de.map((title, i) => ({ title, images: categoryImages[i] }))
};
const content = {
  nl: {
    title: "De Peerdestal",
    headline: "De Peerdestal",
    intro: "Overnacht in de sfeervolle 'Peerdestal'. Een unieke plek waar het verleden voelbaar is, maar waar u geniet van hedendaags comfort. De ruimte beschikt over een moderne keuken, vloerverwarming en comfortabele 2-persoons bedden voor een heerlijke nachtrust.",
    specs: ["2 gasten", "1 slaapkamer", "1 tweepersoonsbed", "1 badkamer"],
    galleryTitle: "Sfeerimpressie",
    rules: {
      title: "Goed om te weten",
      items: [
        { label: "Check-in", value: "Vanaf 15:00" },
        { label: "Check-out", value: "Tot 10:30" },
        { label: "Roken", value: "Niet toegestaan" },
        { label: "Huisdieren", value: "Niet toegestaan" }
      ]
    }
  },
  en: {
    title: "The Horse Stable",
    headline: "The Horse Stable",
    intro: "Stay in the atmospheric 'Peerdestal'. A unique place where the past is palpable, but where you enjoy contemporary comfort. The space features a modern kitchen, underfloor heating, and comfortable double beds for a wonderful night's sleep.",
    specs: ["2 guests", "1 bedroom", "1 double bed", "1 bathroom"],
    galleryTitle: "Impressions",
    rules: {
      title: "Good to know",
      items: [
        { label: "Check-in", value: "From 15:00" },
        { label: "Check-out", value: "Until 10:30" },
        { label: "Smoking", value: "Not allowed" },
        { label: "Pets", value: "Not allowed" }
      ]
    }
  },
  de: {
    title: "Der Pferdestall",
    headline: "Der Pferdestall",
    intro: "Übernachten Sie im stimmungsvollen 'Peerdestal'. Ein einzigartiger Ort, an dem die Vergangenheit spürbar ist, Sie aber zeitgemäßen Komfort genießen. Der Raum verfügt über eine moderne Küche, Fußbodenheizung und komfortable Doppelbetten für eine wunderbare Nachtruhe.",
    specs: ["2 Gäste", "1 Schlafzimmer", "1 Doppelbett", "1 Badezimmer"],
    galleryTitle: "Impressionen",
    rules: {
      title: "Gut zu wissen",
      items: [
        { label: "Check-in", value: "Ab 15:00" },
        { label: "Check-out", value: "Bis 10:30" },
        { label: "Rauchen", value: "Nicht erlaubt" },
        { label: "Haustiere", value: "Nicht erlaubt" }
      ]
    }
  }
};

const t = content[lang] || content.nl;
const categories = galleryCategories[lang] || galleryCategories.nl;
---

<Layout title={`Boerderij Voorste Eng - ${t.title}`} lang={lang}>
  
    <RoomHero 
        title={t.headline} 
        subtitle="Otterlo, Hoge Veluwe"
        image="/images/real/rooms/peerdestal/peerdestal-overzicht.avif"
        transitionName="hero-peerdestal"
    />

    <!-- Intro Section Modernized -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-24 mb-24">
        <ScrollReveal animation="fade-up">
            <div class="grid lg:grid-cols-12 gap-16 items-start">
                
                <!-- Left: Typography & Intro -->
                <div class="lg:col-span-8">
                    <h2 class="text-4xl md:text-5xl font-heading font-light text-bordeaux mb-8 leading-tight">
                        {lang === 'nl' ? 'Authentieke details,' : (lang === 'en' ? 'Authentic details,' : 'Authentische Details,')} <br />
                        <span class="text-stone-400 italic font-serif text-3xl md:text-4xl">{lang === 'nl' ? 'hedendaags comfort.' : (lang === 'en' ? 'contemporary comfort.' : 'zeitgemäßer Komfort.')}</span>
                    </h2>
                    <p class="text-stone-600 text-lg md:text-xl font-light leading-relaxed mb-8">
                        {t.intro}
                    </p>
                    <div class="w-16 h-[1px] bg-bordeaux/50"></div>
                </div>

                <!-- Right: Specs Block -->
                <div class="lg:col-span-4 bg-foam-white p-8 rounded-sm border border-stone-100/50">
                    <h3 class="text-sm font-bold tracking-widest uppercase text-stone-400 mb-8">{lang === 'nl' ? 'Specificaties' : (lang === 'en' ? 'Specifications' : 'Spezifikationen')}</h3>
                    <div class="space-y-6">
                        {t.specs.map((spec: string) => {
                            const match = spec.match(/^(\d+)\s+(.+)$/);
                            const value = match ? match[1] : "✓";
                            const label = match ? match[2] : spec;
                            
                            return (
                                <div class="flex items-center gap-4 border-b border-stone-200/50 pb-4 last:border-0 last:pb-0">
                                    <div class="w-10 h-10 flex items-center justify-center rounded-full bg-white text-bordeaux font-heading text-xl shadow-sm">
                                        {value}
                                    </div>
                                    <span class="text-stone-600 uppercase tracking-wider text-xs font-semibold">{label}</span>
                                </div>
                            );
                        })}
                    </div>
                </div>

            </div>
        </ScrollReveal>
    </div>

    <!-- Gallery / Carousel -->
    <div class="max-w-[100rem] mx-auto px-4 sm:px-6 lg:px-8 mb-24">
        <CategorizedGallery categories={categories} />
    </div>

    <!-- Info / Rules Section -->
    <div class="bg-foam-white p-12 lg:p-20 rounded-sm border border-stone-100 relative overflow-hidden">
        <ScrollReveal animation="fade-up">
            <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                   <h3 class="text-3xl font-heading font-light text-bordeaux mb-6">{t.rules.title}</h3>
                   <p class="text-slate-600 mb-8">{lang === 'nl' ? 'Wij zorgen voor een zorgeloos verblijf. Hier zijn enkele praktische zaken.' : 'We ensure a carefree stay. Here are some practical matters.'}</p>
                </div>
                
                <div class="bg-white p-8 shadow-sm">
                   <ul class="space-y-4">
                      {t.rules.items.map(item => (
                          <li class="flex justify-between items-center border-b border-stone-100 pb-2 last:border-0 last:pb-0">
                              <span class="font-bold text-slate-700">{item.label}</span>
                              <span class="text-slate-500">{item.value}</span>
                          </li>
                      ))}
                   </ul>
                </div>
            </div>
            
            <!-- Background Watermark -->
            <div class="absolute -top-20 -right-20 text-[20rem] font-heading text-bordeaux/5 leading-none select-none pointer-events-none">
                PS
            </div>
        </ScrollReveal>
    </div>

  </div>
  </div>
</Layout>

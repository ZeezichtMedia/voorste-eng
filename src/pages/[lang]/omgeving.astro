      cultuur: "Cultuur",
      dining: "Eten & Drinken",
      highlights: "Highlights"
    },
    spotsTitle: "Hotspots",
    spots: [
      { 
        title: "Nationaal Park De Hoge Veluwe", 
        desc: "5.400 hectare natuur met bossen, heide en zandverstuivingen. Perfect voor wandelen, fietsen en wild spotten vlak bij Otterlo.", 
        img: "/images/hoge_veluwe_park.png",
        link: "https://www.hogeveluwe.nl"

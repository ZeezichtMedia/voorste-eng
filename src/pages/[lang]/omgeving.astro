      { 
        title: "Museonder", 
        desc: "The first underground museum in the world, located in the middle of National Park De Hoge Veluwe. Discover what lives and lived underground on the Veluwe.", 
        img: "/images/museonder.webp",
        link: "https://hogeveluwe.nl/plan-je-bezoek/beleef-het-park/museonder",
        category: "Culture"
      },
      { 
        title: "Kröller-Müller Museum", 
        desc: "Museum located in the middle of De Hoge Veluwe with one of the largest Van Gogh collections in the world and an impressive sculpture garden.", 
        img: "/images/kroller_muller.jpeg",
        link: "https://krollermuller.nl/en",
        category: "Culture"
      },
      { 
        title: "Planken Wambuis", 
        desc: "Extensive nature reserve with heathlands, forests, and a high chance of spotting red deer or wild boars.", 
        img: "/images/planken_wambuis.jpg",
        link: "https://www.natuurmonumenten.nl/natuurgebieden/planken-wambuis",
        category: "Highlights"
      },
      {
        title: "De Waldhoorn",
        desc: "Cozy restaurant in the center of Otterlo for lunch, dinner, or a drink after a day on the Veluwe.",
        img: "/images/de_waldhoorn.jpg",
        link: "https://www.de-waldhoorn.nl/en/",
        category: "Dining & Drinks"
      }
    ],
    dining: [
      { name: "Grand Café Kröller", desc: "Delicious lunch or dinner in the heart of Otterlo.", img: "/images/restaurant_farmhouse.png" },
      { name: "Carnegie Cottage", desc: "Atmospheric restaurant with terrace.", img: "/images/restaurant_fine.png" }
    ],
    sights: [
      { name: "Dutch Tile Museum", desc: "Unique collection of historical Dutch wall tiles.", img: "/images/tile_museum.png" },
      { name: "Radio Kootwijk", desc: "Impressive art-deco transmitter station in the middle of the heath.", img: "/images/radio_kootwijk.png" },
      { name: "Watchtower De Valouwe", desc: "Spectacular view over the treetops of the Veluwe.", img: "/images/observation_tower.png" }

const t = content[lang] || content.nl;
---

<Layout title={`Boerderij Voorste Eng - ${t.title}`} lang={lang}>
  
  <div class="relative bg-stone-50 pt-32 pb-16 md:py-32 text-center text-slate-800 px-4">
      <ScrollReveal animation="fade-up">
         <h1 class="font-heading text-5xl md:text-7xl font-light mb-8 text-bordeaux tracking-tight">{t.headline}</h1>
         <p class="max-w-2xl mx-auto text-stone-600 text-xl font-light leading-relaxed">{t.description}</p>
         <div class="w-16 h-[1px] bg-bordeaux/30 mx-auto mt-12"></div>
      </ScrollReveal>
  </div>

  <div class="bg-white overflow-hidden">
    {/* De Mossel History Section */}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 border-b border-stone-100">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <ScrollReveal animation="fade-right">
                <div class="relative aspect-[4/5] rounded-tl-3xl rounded-br-3xl overflow-hidden shadow-2xl">
                    <ParallaxImage src={t.history.image} alt={t.history.title} class="w-full h-full object-cover" height="h-[120%]" />
                    <div class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-tl-3xl rounded-br-3xl"></div>
                </div>
            </ScrollReveal>
            
            <ScrollReveal animation="fade-left" delay={0.2}>
                <div>
                    <span class="text-bordeaux font-bold tracking-widest uppercase text-sm mb-4 block">Historie</span>
                    <h2 class="font-heading text-4xl md:text-5xl text-slate-900 mb-8 leading-tight">{t.history.title}</h2>
                    <div class="space-y-6 text-stone-600 leading-relaxed font-light text-lg">
                        {t.history.paragraphs.map(p => (
                            <p>{p}</p>
                        ))}
                    </div>
                </div>
            </ScrollReveal>
        </div>
    </div>

    {/* Eten & Drinken */}
    <div class="bg-stone-50 py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ScrollReveal animation="fade-up">
                <div class="text-center mb-16">
                    <h2 class="font-heading text-4xl md:text-5xl text-slate-900 mb-4">{t.sections.dining}</h2>
                    <div class="w-16 h-[1px] bg-bordeaux/30 mx-auto"></div>
                </div>
            </ScrollReveal>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                {t.dining.map((item, i) => {
                    const CardTag = item.link ? 'a' : 'div';
                    const cardProps = item.link ? { href: item.link, target: "_blank", rel: "noopener noreferrer" } : {};
                    return (
                    <ScrollReveal animation="fade-up" delay={(i % 4) * 0.1}>
                        <CardTag {...cardProps} class={`group block h-full bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden transform hover:-translate-y-1 border border-stone-100 ${item.link ? 'cursor-pointer' : ''}`}>
                            <div class="aspect-[4/3] relative overflow-hidden">
                                <img src={item.img} alt={item.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                                <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors"></div>
                            </div>
                            <div class="p-6 flex flex-col h-full">
                                <h3 class="font-heading text-xl text-slate-900 mb-3 group-hover:text-bordeaux transition-colors">{item.title}</h3>
                                <p class="text-stone-500 font-light text-sm leading-relaxed mb-4 flex-grow">{item.desc}</p>
                            </div>
                        </CardTag>
                    </ScrollReveal>
                    );
                })}
            </div>
        </div>
    </div>

    {/* IJstips */}
    <div class="py-24 bg-gradient-to-br from-amber-50 via-orange-50 to-rose-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ScrollReveal animation="fade-up">
                <div class="text-center mb-16">
                    <span class="text-bordeaux font-bold tracking-widest uppercase text-sm mb-4 block">🍦</span>
                    <h2 class="font-heading text-4xl md:text-5xl text-slate-900 mb-4">{t.sections.icecream}</h2>
                    <div class="w-16 h-[1px] bg-bordeaux/30 mx-auto"></div>
                </div>
            </ScrollReveal>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {t.icecream.map((item, i) => (
                    <ScrollReveal animation="fade-up" delay={i * 0.1}>
                        <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 p-8 h-full flex flex-col items-center text-center group border border-stone-100">
                            <div class="w-24 h-24 rounded-full overflow-hidden mb-6 ring-4 ring-amber-100 group-hover:ring-bordeaux/30 transition-all shadow-lg group-hover:scale-105">
                                <img src={item.img} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
                            </div>
                            <h3 class="font-heading text-xl text-slate-900 mb-3 group-hover:text-bordeaux transition-colors">{item.title}</h3>
                            <p class="text-stone-600 font-light leading-relaxed text-sm">{item.desc}</p>
                        </div>
                    </ScrollReveal>
                ))}
            </div>
        </div>
    </div>

    {/* Activiteiten & Bezienswaardigheden */}
    <div class="py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ScrollReveal animation="fade-up">
                <div class="flex items-center justify-between mb-12">
                    <h2 class="font-heading text-4xl text-slate-900">{t.sections.sights}</h2>
                    <div class="h-[1px] flex-1 bg-stone-200 ml-8 max-w-sm hidden md:block"></div>
                </div>
            </ScrollReveal>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
                {t.sights.map((item, i) => {
                    const CardTag = item.link ? 'a' : 'div';
                    const cardProps = item.link ? { href: item.link, target: "_blank", rel: "noopener noreferrer" } : {};
                    return (
                    <ScrollReveal animation="fade-up" delay={i * 0.1}>
                        <CardTag {...cardProps} class={`group block h-full flex flex-col ${item.link ? 'cursor-pointer' : ''}`}>
                            <div class="aspect-[16/10] rounded-xl overflow-hidden mb-6 relative">
                                <img src={item.img} alt={item.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            </div>
                            <h3 class="font-heading text-2xl text-slate-900 mb-3 group-hover:text-bordeaux transition-colors">{item.title}</h3>
                            <p class="text-stone-500 font-light leading-relaxed flex-grow">{item.desc}</p>
                        </CardTag>
                    </ScrollReveal>
                    );
                })}
            </div>
        </div>
    </div>

    {/* Wandelen */}
    <div class="bg-stone-50 py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ScrollReveal animation="fade-up">
                <h2 class="font-heading text-4xl md:text-5xl text-slate-900 mb-12 text-center">{t.sections.walking}</h2>
            </ScrollReveal>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {t.walking.map((item, i) => (
                    <ScrollReveal animation="fade-up" delay={i * 0.1}>
                        <div class="bg-white rounded-xl shadow-sm border border-stone-100 overflow-hidden h-full flex flex-col group hover:shadow-xl transition-shadow duration-300">
                            <div class="aspect-video relative overflow-hidden">
                                <img src={item.img} alt={item.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                            </div>
                            <div class="p-8 flex-1 flex flex-col">
                                <h3 class="font-heading text-xl text-slate-900 mb-3 group-hover:text-bordeaux transition-colors">{item.title}</h3>
                                <p class="text-stone-500 font-light text-sm leading-relaxed flex-1">{item.desc}</p>
                                {item.link && (
                                    <a href={item.link} target="_blank" class="mt-6 inline-flex items-center text-sm font-bold uppercase tracking-widest text-bordeaux hover:text-slate-900 transition-colors">
                                        {t.readMore}
                                        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </a>
                                )}
                            </div>
                        </div>
                    </ScrollReveal>
                ))}
            </div>
        </div>
    </div>

    {/* Surroundings */}
    <div class="py-24 border-t border-stone-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ScrollReveal animation="fade-up">
                <div class="text-center mb-16">
                    <h2 class="font-heading text-3xl md:text-4xl text-slate-900 mb-4">{t.sections.surroundings}</h2>
                    <div class="w-16 h-[1px] bg-bordeaux/30 mx-auto"></div>
                </div>
            </ScrollReveal>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
                {t.surroundings.map((item, i) => {
                    const CardTag = item.link ? 'a' : 'div';
                    const cardProps = item.link ? { href: item.link, target: "_blank", rel: "noopener noreferrer" } : {};
                    return (
                    <ScrollReveal animation="fade-up" delay={i * 0.1}>
                        <CardTag {...cardProps} class={`flex flex-col sm:flex-row group bg-white border border-stone-100 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 h-full ${item.link ? 'cursor-pointer' : ''}`}>
                            <div class="w-full sm:w-2/5 aspect-[4/3] sm:aspect-auto relative overflow-hidden">
                                <img src={item.img} alt={item.title} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" loading="lazy" />
                            </div>
                            <div class="p-8 w-full sm:w-3/5 flex flex-col justify-center">
                                <h3 class="font-heading text-xl text-slate-900 mb-3 group-hover:text-bordeaux transition-colors">{item.title}</h3>
                                <p class="text-stone-500 font-light text-sm leading-relaxed">{item.desc}</p>
                            </div>
                        </CardTag>
                    </ScrollReveal>
                    );
                })}
            </div>
        </div>
    </div>

  </div>
</Layout>
